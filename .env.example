# ============================================================================
# LLM PROVIDERS (set the ones you use)
# ============================================================================

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# xAI Grok
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# QWEN Cloud (Alibaba DashScope) - International and China regions
# Get API keys from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=
QWEN_CN_API_KEY=
# (Backward compatible aliases; will be auto-detected)
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=

# GLM / Zhipu (Z.AI international and BigModel China)
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=

# MiniMax (global and China)
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=

# OpenRouter (multi-provider aggregator)
OPENROUTER_API_KEY=

# ============================================================================
# QWEN CLOUD CONFIGURATION (for Alibaba DashScope)
# ============================================================================

# Get API keys from: https://dashscope.console.aliyun.com/
# - qwen-3.7-max: Premium flagship, best for complex analysis
# - qwen-3.6-plus: Balanced, strong agent capabilities
# - qwen-3.6-flash: Fast execution for real-time decisions
# - qwen-3.5-flash: Previous-gen fast model
#
# International endpoints use QWEN_API_KEY
# China endpoints use QWEN_CN_API_KEY
# Models are the same across both regions
#
# Example: Use QWEN with qwen-3.7-max for deep analysis
# TRADINGAGENTS_LLM_PROVIDER=qwen
# TRADINGAGENTS_DEEP_THINK_LLM=qwen3.7-max
# TRADINGAGENTS_QUICK_THINK_LLM=qwen3.6-flash

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# ============================================================================
# TRADINGAGENTS CORE CONFIGURATION
# ============================================================================
# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# In the CLI, setting the LLM provider / models / backend URL / language
# also skips the matching interactive selection step (useful for
# OpenAI-compatible endpoints like opencode or LM Studio, and unattended runs).

# LLM Provider selection (openai, anthropic, google, qwen, qwen-cn, deepseek, glm, minimax, etc.)
#TRADINGAGENTS_LLM_PROVIDER=qwen

# Models for deep reasoning (complex analysis, debate, risk assessment)
# QWEN options: qwen3.7-max, qwen3.6-plus
#TRADINGAGENTS_DEEP_THINK_LLM=qwen3.7-max

# Models for quick decisions (simple analysis, fast execution)
# QWEN options: qwen3.6-flash, qwen3.5-flash
#TRADINGAGENTS_QUICK_THINK_LLM=qwen3.6-flash

# Custom backend URL (for proxies or self-hosted endpoints)
#TRADINGAGENTS_LLM_BACKEND_URL=

# Output language for analysis reports
#TRADINGAGENTS_OUTPUT_LANGUAGE=English

# Analysis parameters
# Number of rounds for bull/bear debate (higher = more thorough analysis)
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=2

# Number of rounds for risk discussion (higher = more conservative)
#TRADINGAGENTS_MAX_RISK_ROUNDS=1

# Enable checkpoint/resume for long-running analyses
#TRADINGAGENTS_CHECKPOINT_ENABLED=false

# Sampling temperature (lower = less variation, higher = more creative)
# QWEN default is ~0.7, range is 0.0-1.0
#TRADINGAGENTS_TEMPERATURE=0.7

# ============================================================================
# TRADING AUTOMATION CONFIGURATION
# ============================================================================
# Enable semi-automated or fully-automated trading execution

# Execution mode: manual | semi_auto | fully_auto
# - manual: Show recommendations only, require manual approval for all trades
# - semi_auto: Auto-execute only if confidence score >= threshold (RECOMMENDED)
# - fully_auto: Execute all trades with risk controls
TRADING_EXECUTION_MODE=semi_auto

# Confidence threshold for semi-auto execution (0.0-1.0)
# Only trades with confidence >= this value auto-execute
# 0.75 = 75% confidence required (good balance of accuracy and execution)
TRADING_CONFIDENCE_THRESHOLD=0.75

# Maximum position size as % of portfolio per trade (0.0-100.0)
# Prevents over-concentration in single trades
TRADING_MAX_POSITION_SIZE=5.0

# Dry-run mode: simulate trades without actual execution
# Set to "true" for testing trading automation logic
TRADING_DRY_RUN=false

# Path to audit log file for trade history and analysis
# JSON lines format (one JSON object per line)
TRADING_AUDIT_LOG_PATH=./trading_audit.log

# ============================================================================
# ALPACA TRADING BROKER (for order execution)
# ============================================================================
# Get API keys from: https://app.alpaca.markets/

# Alpaca API credentials (for actual order execution)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading mode (use paper account for testing)
# Set to "true" for paper trading, omit or "false" for live trading
# WARNING: Live trading uses real money!
ALPACA_PAPER=true

# ============================================================================
# WEB APPLICATION CONFIGURATION
# ============================================================================

# Port for FastAPI web server
PORT=8000

# Maximum analyses to keep in memory
TRADINGAGENTS_WEB_MAX_ANALYSES=100
